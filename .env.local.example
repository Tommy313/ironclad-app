# ============================================================
# IRONCLAD NEXT.JS — Environment Variables
# Copy to .env.local in your Next.js project root
# NEVER commit .env.local to GitHub
# ============================================================

# Supabase — ANON KEY (safe to expose to browser, read-only by RLS)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Railway RAG backend URL (no trailing slash)
NEXT_PUBLIC_RAILWAY_URL=https://your-ironclad-rag.railway.app

# Only needed if you expose ingest from the Next.js app (optional)
# Most ingest happens server-side via Railway — omit if not needed
INGEST_API_KEY=your-ingest-api-key-from-railway-backend
